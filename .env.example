# Copy to .env.local and fill in. .env.local is gitignored; this file is safe to commit.
# Server-side only — never expose to the client (utom NEXT_PUBLIC_*).

# Publik bas-URL (för metadata, robots, sitemap)
NEXT_PUBLIC_SITE_URL=https://valkompass.example.se

# Anthropic API (per-användare-analys + admin-positionsförslag)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MODEL_ANALYSIS=claude-opus-4-8
MODEL_POSITIONS=claude-opus-4-8

# Postgres (utan denna används in-memory-store — OBLIGATORISK i produktion)
# DATABASE_URL=postgres://user:pass@host:5432/valkompass

# Upstash Redis för rate limiting + budget-spärr (OBLIGATORISK på Vercel/serverless)
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx
RATE_LIMIT_PER_MIN=20
DAILY_AI_CALL_BUDGET=500

# Admin-route + admin-UI (granskning/godkännande)
# ADMIN_TOKEN=byt-till-en-lang-slumpmassig-strang

# Skyddar den schemalagda gallrings-cronen (Vercel Cron skickar Bearer ${CRON_SECRET})
# CRON_SECRET=byt-till-en-lang-slumpmassig-strang

# Samtyckesbannerns version (loggas med varje samtycke)
CONSENT_BANNER_VERSION=v1
